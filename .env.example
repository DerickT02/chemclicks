# Copy to `.env.local` and fill in values from your Supabase project:
# Dashboard → Project Settings → API

# Public (safe to expose in the browser; used by `@supabase/ssr` / client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Add this exact redirect in Supabase → Authentication → URL Configuration → Redirect URLs:
# http://localhost:3000/auth/callback

# Vitest database tests (`npm test`) also need the service role key (server-only; never expose to the browser).
# Put these in `.env.test.local` (gitignored) or merge into `.env.local` for local runs:
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

